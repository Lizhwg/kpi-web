<IfModule mod_rewrite.c>
    RewriteEngine On
    RewriteBase /KPI/KPI/kpi-web/
    
    # Cho phép các file và thư mục thực tế truy cập trực tiếp
    RewriteCond %{REQUEST_FILENAME} !-f
    RewriteCond %{REQUEST_FILENAME} !-d
    
    # Điều hướng tất cả request đến index.php
    RewriteRule ^(.*)$ index.php [QSA,L]
</IfModule>
