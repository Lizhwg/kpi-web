DB_HOST=localhost
DB_NAME=kpi_system
DB_USER=root
DB_PASS=

# Cấu hình ứng dụng
APP_ENV=development
APP_DEBUG=true
APP_NAME=KPI System
APP_URL=http://localhost/KPI/kpi-web

# Cấu hình Java API
REDMINE_API_URL=http://localhost:8080/api
REDMINE_API_KEY=your-secret-api-key-here

# Session
SESSION_TIMEOUT=3600
SESSION_NAME=kpi_session

# Logging
LOG_LEVEL=debug
LOG_FILE=/logs/kpi.log
